# Maintainer: Wheatley Linux
pkgname=wheatley-installer
pkgver=1
pkgrel=5
pkgdesc="Wheatley Linux TUI installer (Artix base, runit, CachyOS kernel)"
arch=('any')
url="https://github.com/Vifuddyxg"
license=('MIT')
depends=('bash' 'libnewt' 'artools-base' 'gptfdisk' 'dosfstools' 'e2fsprogs'
         'parted')
# pacman.conf is staged next to this PKGBUILD by scripts/make-iso.sh (copied from
# repo/pacman.conf) — makepkg won't resolve a ../../ relative source path.
source=('wheatley-install'
        'pacman.conf')
sha256sums=('SKIP' 'SKIP')

package() {
    install -Dm755 "$srcdir/wheatley-install" "$pkgdir/usr/bin/wheatley-install"
    install -Dm644 "$srcdir/pacman.conf"      "$pkgdir/usr/share/wheatley/pacman.conf"
}
