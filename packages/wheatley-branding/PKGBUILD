# Maintainer: Wheatley Linux
pkgname=wheatley-branding
pkgver=1
pkgrel=3
pkgdesc="Wheatley Linux branding: amber TTY palette, /etc/issue, os-release, fastfetch logo"
arch=('any')
url="https://github.com/Vifuddyxg"
license=('MIT')
depends=('kbd')                 # setvtrgb
optdepends=('fastfetch: system info splash with the Wheatley logo')
backup=('etc/wheatley/fastfetch.jsonc')
install='wheatley-branding.install'
source=('logo.txt' 'fastfetch.jsonc' 'term-neutral.sh')
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    # ----- fastfetch logo + config -----
    install -Dm644 "$srcdir/logo.txt"       "$pkgdir/usr/share/wheatley/logo.txt"
    install -Dm644 "$srcdir/fastfetch.jsonc" "$pkgdir/etc/wheatley/fastfetch.jsonc"
    install -Dm644 "$srcdir/term-neutral.sh" "$pkgdir/usr/share/wheatley/term-neutral.sh"

    # fastfetch (type:file) treats '$' as a colour placeholder, which both eats
    # the art and miscomputes the logo width -> a huge gap before the info. Ship
    # a '$'-escaped copy ('$$' = literal '$') just for fastfetch; the raw logo.txt
    # is still used by neofetch (which doesn't interpret '$').
    sed 's/\$/$$/g' "$srcdir/logo.txt" > "$srcdir/logo-fastfetch.txt"
    install -Dm644 "$srcdir/logo-fastfetch.txt" "$pkgdir/usr/share/wheatley/logo-fastfetch.txt"

    # ----- make the Wheatley logo the default for a bare `fastfetch`/`neofetch`
    #       too (not just the shell splash): ship configs in /etc/skel so every
    #       new user picks up the logo automatically. -----
    install -Dm644 "$srcdir/fastfetch.jsonc" "$pkgdir/etc/skel/.config/fastfetch/config.jsonc"
    install -Dm644 /dev/stdin "$pkgdir/etc/skel/.config/neofetch/config.conf" <<'EOF'
# Wheatley neofetch config — use the Wheatley ASCII logo and amber colour.
print_info() {
    info title
    info underline
    info "OS" distro
    info "Kernel" kernel
    info "WM" wm
    info "Shell" shell
    info "Packages" packages
    info "Memory" memory
    info "Uptime" uptime
    info cols
}
image_backend="ascii"
image_source="/usr/share/wheatley/logo.txt"
ascii_colors=(3 3 3 3 3 3)
colors=(3 3 3 3 3 7)
EOF

    # ----- os-release (staged; the .install scriptlet copies it to
    #       /usr/lib/os-release, which is owned by the filesystem package) -----
    install -Dm644 /dev/stdin "$pkgdir/usr/share/wheatley/os-release" <<'EOF'
NAME="Wheatley Linux"
PRETTY_NAME="Wheatley Linux"
ID=wheatley
ID_LIKE=artix
BUILD_ID=rolling
ANSI_COLOR="0;33"
HOME_URL="https://github.com/Vifuddyxg"
LOGO=wheatley
EOF

    # ----- amber console palette (setvtrgb: red / green / blue lines) -----
    # Color 7 = the default TTY foreground; set it to apeturewm's primary text
    # color COL_TEXT #F1B00A (241,176,10) so console text matches the WM.
    install -Dm644 /dev/stdin "$pkgdir/etc/wheatley/console-colors" <<'EOF'
16,179,138,166,107,154,192,241,90,217,182,241,138,196,224,241
10,64,122,105,90,90,134,176,68,88,160,176,116,114,165,176
2,42,31,0,42,58,26,10,34,58,42,10,58,74,42,10
EOF

    # apply the palette on real TTYs at login
    install -Dm644 /dev/stdin "$pkgdir/etc/profile.d/wheatley-console.sh" <<'EOF'
# Wheatley amber console palette — only on real virtual terminals
case "$(tty)" in
    /dev/tty[0-9]*)
        command -v setvtrgb >/dev/null 2>&1 && \
            setvtrgb /etc/wheatley/console-colors 2>/dev/null
        ;;
esac
EOF

    # ----- issue with amber Wheatley banner (literal ESC for agetty); staged,
    #       the .install scriptlet copies it to /etc/issue (owned by filesystem) -----
    printf '\033[1;33m\n' >  "$srcdir/issue"
    cat >> "$srcdir/issue" <<'EOF'
__        __ _   _  _____     _     _____  _      _____ __   __
\ \      / /| | | || ____|   / \   |_   _|| |    | ____|\ \ / /
 \ \ /\ / / | |_| ||  _|    / _ \    | |  | |    |  _|   \ V /
  \ V  V /  |  _  || |___  / ___ \   | |  | |___ | |___   | |
   \_/\_/   |_| |_||_____|/_/   \_\  |_|  |_____||_____|  |_|
EOF
    printf '\033[0;33m        Wheatley Linux \\r (\\l)\033[0m\n\n' >> "$srcdir/issue"
    install -Dm644 "$srcdir/issue" "$pkgdir/usr/share/wheatley/issue"
}
