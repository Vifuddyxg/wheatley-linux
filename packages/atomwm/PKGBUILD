# Maintainer: Wheatley Linux
pkgname=atomwm
pkgver=r1
pkgrel=2
pkgdesc="The lightest possible X11 window manager: monocle, raw X protocol, no libc deps"
arch=('x86_64')
url="https://github.com/Vifuddyxg/atomwm"
license=('custom')
# talks raw X11 over the socket (no link-time X libs); runtime deps below are
# for the session wrapper: startx to bring up X, dbus for the session bus.
depends=('xorg-xinit' 'dbus')
optdepends=('st-wheatley: terminal' 'rofi: launcher'
            'xorg-server: X server' 'pipewire: audio'
            'wireplumber: audio session manager'
            'pipewire-pulse: PulseAudio-compatible audio')
makedepends=('git')
# atomwm is a freestanding, -nostdlib program with its own _start/cstart entry.
# Its Makefile supplies the required flags via ?= (CFLAGS/LDFLAGS). makepkg's
# exported buildflags would suppress those defaults and link the standard C
# runtime (Scrt1.o) -> duplicate `_start`. Disable makepkg's flag injection so
# the Makefile's freestanding flags take effect; the upstream Makefile strips.
options=('!buildflags' '!lto' '!debug' '!strip')
source=("git+https://github.com/Vifuddyxg/atomwm.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$srcdir/$pkgname"
    # default terminal -> Wheatley-themed st
    sed -i 's/cmd_term   = "alacritty"/cmd_term   = "st"/' config.h
}

build() {
    cd "$srcdir/$pkgname"
    make
}

package() {
    cd "$srcdir/$pkgname"
    make PREFIX=/usr DESTDIR="$pkgdir" install

    # session wrapper (starts X under a TUI greeter + dbus + audio, like apeturewm's)
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/atomwm-session" <<'EOF'
#!/bin/sh
# atomwm-session — login session wrapper for greeters / display managers.
# Starts X if launched from a TUI greeter (greetd/tuigreet) with no display,
# then audio (pipewire) + session bus, then the WM.
if [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ] && [ -z "${ATOMWM_XSTARTED:-}" ]; then
    ATOMWM_XSTARTED=1; export ATOMWM_XSTARTED
    exec startx "$0" -- "vt${XDG_VTNR:-1}"
fi
export XDG_CURRENT_DESKTOP=atomwm
export XDG_SESSION_DESKTOP=atomwm
export XDG_SESSION_TYPE=x11
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24
exec dbus-run-session sh -lc '
  command -v pipewire       >/dev/null 2>&1 && pipewire &
  command -v wireplumber    >/dev/null 2>&1 && wireplumber &
  command -v pipewire-pulse >/dev/null 2>&1 && pipewire-pulse &
  exec atomwm
'
EOF

    # xsession entry
    install -Dm644 /dev/stdin "$pkgdir/usr/share/xsessions/atomwm.desktop" <<'EOF'
[Desktop Entry]
Name=atomwm
Comment=Ultra-minimal monocle window manager for X11
Exec=/usr/bin/atomwm-session
TryExec=/usr/bin/atomwm
Type=XSession
DesktopNames=atomwm
Keywords=monocle;wm;
EOF

    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
