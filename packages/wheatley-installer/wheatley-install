#!/usr/bin/env bash
# wheatley-install — Wheatley Linux installer
#
# A light whiptail TUI with two modes:
#   * Offline express — copies the ready-made live system to disk, no internet
#     needed (runit + apeturewm desktop + CachyOS kernel, fixed setup).
#   * Custom online   — pick init system, window manager(s), minimal vs desktop,
#     network manager and more; downloads packages (needs internet).
#
# Every question has a Back button, so you can step backwards at any point.
# Nothing on disk changes until the final "Review your choices" -> Yes.
#
# Run from the live ISO:  sudo wheatley-install
set -uo pipefail        # NOTE: no -e here; the wizard manages flow via returns.
                        # The execution block runs under its own `set -e`.

# ----- constants --------------------------------------------------------------
PACCONF=/usr/share/wheatley/pacman.conf      # repos: artix + cachyos + wheatley
TITLE="Wheatley Linux Installer"
LOG=/tmp/wheatley-install.log
FAILMARK=/tmp/wheatley-install.fail
OKMARK=/tmp/wheatley-install.ok
: >"$LOG"; rm -f "$FAILMARK" "$OKMARK"

# Wheatley palette (amber on near-black) — also exported to whiptail
export NEWT_COLORS='
root=,black
window=,black
border=yellow,black
title=yellow,black
textbox=yellow,black
listbox=yellow,black
actlistbox=black,yellow
button=black,yellow
actbutton=black,yellow
checkbox=yellow,black
actcheckbox=black,yellow
entry=yellow,black
label=yellow,black
'

die()  { whiptail --title "$TITLE" --scrolltext --msgbox \
         "ERROR: $1

--- last lines of $LOG ---
$(tail -n 30 "$LOG" 2>/dev/null)" 24 78; exit 1; }
log()  { printf '\n=== %s ===\n' "$1" >>"$LOG"; }
# Inside the gauge pipe, stdout is the progress bar — drawing a dialog there
# would be swallowed. So on failure we record the step and exit the subshell;
# the caller after the pipe shows a real error dialog.
run()  { local name="$1"; log "$name"; shift; \
         "$@" >>"$LOG" 2>&1 || { printf '%s: %s\n' "$name" "$*" >"$FAILMARK"; exit 1; }; }
msg()  { whiptail --title "$1" --msgbox "$2" "${3:-12}" "${4:-70}"; }

# ----- back-navigable prompt helpers -----------------------------------------
# Each returns 0 (OK, answer in $REPLY) or 10 (Back / Esc). The wizard loop
# turns a 10 into "go to the previous step".
ask_input() {  # title prompt default
    local r; r=$(whiptail --title "$1" --cancel-button "Back" \
        --inputbox "$2" 11 72 "$3" 3>&1 1>&2 2>&3)
    [ $? -eq 0 ] && { REPLY=$r; return 0; }; return 10
}
ask_pass() {   # title prompt
    local r; r=$(whiptail --title "$1" --cancel-button "Back" \
        --passwordbox "$2" 12 72 3>&1 1>&2 2>&3)
    [ $? -eq 0 ] && { REPLY=$r; return 0; }; return 10
}
ask_menu() {   # title prompt tag1 item1 tag2 item2 ...
    local t=$1 p=$2; shift 2
    local n=$(( $# / 2 )); [ "$n" -gt 9 ] && n=9
    local r; r=$(whiptail --title "$t" --notags --cancel-button "Back" \
        --menu "$p" 20 78 "$n" "$@" 3>&1 1>&2 2>&3)
    [ $? -eq 0 ] && { REPLY=$r; return 0; }; return 10
}

# ----- preflight --------------------------------------------------------------
[ "$(id -u)" -eq 0 ] || { echo "run as root"; exit 1; }
command -v whiptail >/dev/null || { echo "whiptail missing"; exit 1; }
if [ -d /sys/firmware/efi/efivars ]; then FIRMWARE=uefi; else FIRMWARE=bios; fi

# Keep the console quiet so kernel logs and chatty daemons don't paint over the
# TUI.  ModemManager is the worst offender: it's NOT a runit service — Network
# Manager D-Bus-activates it, so stopping/killing it just makes NM relaunch it.
# The only reliable cure is to neutralise its D-Bus activation file (and the
# kernel printk level for good measure).  All best-effort; never aborts install.
quiet_console() {
    echo 1 >/proc/sys/kernel/printk 2>/dev/null || true
    dmesg -n 1 2>/dev/null || true
    udevadm control --log-level=err 2>/dev/null || true
    setterm --msg off 2>/dev/null || true
    # stop ModemManager being re-spawned over the console by D-Bus
    local f
    for f in /usr/share/dbus-1/system-services/org.freedesktop.ModemManager1.service \
             /usr/lib/systemd/system/ModemManager.service; do
        [ -e "$f" ] && mv -f "$f" "$f.wheatley-disabled" 2>/dev/null || true
    done
    pkill -x ModemManager 2>/dev/null || true
}
quiet_console

# ----- defaults (set -u safe; steps overwrite as needed) ----------------------
MODE=online
KEYMAP=us; LOCALE=en_US.UTF-8; TZ=Europe/Bucharest; HOSTNAME=wheatley
USERNAME=wheatley; USERPW=""; ROOTPW=""
INIT=runit; INIT_BASE=""; GREETD_SVC=""
NETWORK=networkmanager; NET_PKGS=""; NET_SERVICE=""; NET_APPLET=""
PROFILE=desktop; WMS=apeturewm; GREETER=greetd; TERMCOLOR=amber
PART_MODE=""; DISK=""; ROOT=""; ESP=""; ROOT_PART=""; ESP_PART=""
FORMAT_ROOT=yes; FORMAT_ESP=no; SWAP=2; TARGET_DESC=""

whiptail --title "$TITLE" --msgbox \
"Welcome to Wheatley Linux.

This wizard installs Wheatley on your computer in a few steps.
Every screen has a Back button, so you can go back any time.

Nothing on any disk is changed until you reach the final
review screen and choose 'Yes'." 15 72

# =============================================================================
#  STEP FUNCTIONS  (return 0 = next, 10 = back)
# =============================================================================

# --- network (online only): connect via cable or Wi-Fi (nmtui) ---------------
net_ok() { ping -c1 -W3 artixlinux.org >/dev/null 2>&1; }
s_net() {
    if net_ok; then return 0; fi
    while true; do
        ask_menu "Network" \
"Wheatley needs the internet to download packages for a custom
install.  How do you want to connect?" \
"wired" "Wired  - I plugged in a network cable (check again)" \
"wifi"  "Wi-Fi  - open the Wi-Fi connector (nmtui)" \
"skip"  "Continue without internet (not recommended)" || return 10
        case "$REPLY" in
            wired) net_ok && return 0
                   msg "Network" "Still no connection over the cable.\n\nCheck it's plugged in and try again, or use Wi-Fi." 10 62 ;;
            wifi)  clear; nmtui; net_ok && return 0
                   msg "Network" "Not connected yet.\n\nTry Wi-Fi again, or plug in a cable." 10 62 ;;
            skip)  whiptail --title "Network" --yesno \
"Without internet a custom (online) install WILL fail partway.

Tip: go Back to the start and pick 'Offline express' instead —
it needs no internet at all.

Continue without internet anyway?" 14 66 && return 0 ;;
        esac
    done
}

s_keyboard() {
    ask_menu "Keyboard layout" \
"Pick your keyboard layout (how the keys are mapped).
If you're not sure, leave it on US English." \
"us"    "US English (QWERTY)" \
"uk"    "UK English" \
"de"    "German (QWERTZ)" \
"fr"    "French (AZERTY)" \
"es"    "Spanish" \
"it"    "Italian" \
"ro"    "Romanian" \
"ru"    "Russian" \
"other" "Other - I'll type the code myself" || return 10
    if [ "$REPLY" = other ]; then
        ask_input "Keyboard layout" "Console keymap code (e.g. us, de-latin1, ro):" "$KEYMAP" || return 10
        KEYMAP=${REPLY:-us}
    else
        KEYMAP=$REPLY
    fi
    return 0
}

s_locale()   { ask_input "Language / locale" "System locale:" "$LOCALE" || return 10; LOCALE=${REPLY:-en_US.UTF-8}; }
s_timezone() { ask_input "Timezone" "Timezone (Region/City):" "$TZ" || return 10; TZ=${REPLY:-UTC}; }
s_hostname() { ask_input "Computer name" "Hostname (the computer's name on the network):" "$HOSTNAME" || return 10
               HOSTNAME=$(echo "${REPLY:-wheatley}" | tr ' ' '-'); }

s_user() {
    ask_input "Your username" "Pick a username (lowercase).  Default is 'wheatley'." "$USERNAME" || return 10
    USERNAME=$(echo "${REPLY:-wheatley}" | tr 'A-Z ' 'a-z-')
    return 0
}
s_pass() {
    ask_pass "Password for $USERNAME" \
"Password for $USERNAME.
Leave blank and press OK to use '$USERNAME' (change it later with passwd)." || return 10
    USERPW=${REPLY:-$USERNAME}
    ask_pass "Administrator (root) password" \
"Root (administrator) password.
Leave blank to reuse the password you just set." || return 10
    ROOTPW=${REPLY:-$USERPW}
    return 0
}

# --- online-only choices ------------------------------------------------------
s_init() {
    ask_menu "Init system" \
"Which init / service manager for the installed system?" \
"dinit"  "dinit  - modern, fast, simple (recommended)" \
"runit"  "runit  - the same init the live ISO runs" \
"openrc" "openrc - battle-tested, Gentoo-style" || return 10
    INIT=$REPLY
    case "$INIT" in
        dinit)  INIT_BASE="dinit elogind-dinit seatd-dinit dbus-dinit";   GREETD_SVC="greetd-dinit" ;;
        runit)  INIT_BASE="runit elogind-runit seatd-runit dbus-runit";   GREETD_SVC="greetd-runit" ;;
        openrc) INIT_BASE="openrc elogind-openrc seatd-openrc dbus-openrc"; GREETD_SVC="greetd-openrc" ;;
    esac
    return 0
}
s_netmgr() {
    ask_menu "Network manager" \
"How should the installed system manage networking?" \
"networkmanager" "NetworkManager - easy wifi (nmtui + tray applet)" \
"connman"        "ConnMan - lighter, connmanctl CLI" || return 10
    NETWORK=$REPLY
    case "$NETWORK" in
        networkmanager) NET_PKGS="networkmanager networkmanager-$INIT wpa_supplicant"; NET_SERVICE="NetworkManager"; NET_APPLET="network-manager-applet" ;;
        connman)        NET_PKGS="connman connman-$INIT wpa_supplicant";               NET_SERVICE="connmand";       NET_APPLET="cmst" ;;
    esac
    return 0
}
s_profile() {
    ask_menu "Install type" "What do you want installed?" \
"desktop" "Desktop - window manager + greeter + audio + apps" \
"minimal" "Minimal - base system + kernel + network only" || return 10
    PROFILE=$REPLY
    if [ "$PROFILE" != desktop ]; then WMS=""; return 0; fi
    whiptail --title "Window managers" --msgbox \
"Wheatley ships two window managers — pick one or both:

apeturewm — a tiling WM. Windows auto-arrange in BSP splits, a
  top status bar, 9 workspaces, an overview, amber theming.
  Keyboard-driven (Super + h/j/k/l). The daily driver.

atomwm — a monocle WM: ONE fullscreen window at a time, no bar,
  no borders. A tiny binary that idles at 0% CPU. Ultra-minimal.

Pick both and choose between them at the login screen." 19 74
    local sel; sel=$(whiptail --title "Window manager" --notags --cancel-button "Back" \
--checklist "Choose window manager(s) — Space toggles, Enter confirms:" 12 74 2 \
"apeturewm" "Tiling: BSP splits, bar, 9 workspaces, overview" ON \
"atomwm"    "Monocle: one fullscreen window, no bar, tiny" OFF \
3>&1 1>&2 2>&3) || return 10
    WMS=$(echo "$sel" | tr -d '"')
    [ -n "$WMS" ] || WMS=apeturewm
    return 0
}
s_termcolor() {
    ask_menu "Terminal colour" \
"How should text look in the terminal and console?

Wheatley can paint everything in its amber/orange theme, or keep
the usual neutral colours.  (You can change this later.)" \
"amber"   "Amber  - everything in Wheatley orange (themed)" \
"neutral" "Normal - standard neutral terminal colours" || return 10
    TERMCOLOR=$REPLY
    return 0
}

# --- storage (both modes) -----------------------------------------------------
list_disks() { lsblk -dno NAME,SIZE,MODEL | awk '{print "/dev/"$1; $1=""; print $0}'; }
list_parts() { lsblk -lnpo NAME,SIZE,FSTYPE,TYPE | awk '$4=="part"{fs=($3==""?"(empty)":$3); print $1; print $2"  "fs}'; }
# find an existing EFI System Partition (GUID c12a7328-...), preferring $1's disk
find_esp() {
    local disk="$1" all same
    all=$(lsblk -lnpo NAME,PARTTYPE | awk 'tolower($2)=="c12a7328-f81f-11d2-ba4b-00a0c93ec93b"{print $1}')
    same=$(echo "$all" | grep -E "^${disk}p?[0-9]+$" | head -1)
    [ -n "$same" ] && { echo "$same"; return; }
    echo "$all" | head -1
}
s_storage() {
    ask_menu "Where to install" \
"Where should Wheatley go?  If unsure, keep the first choice.

  Keep my data   - install onto a partition you pick; your
                   other files and operating systems stay put.
  Use whole disk - set up one disk from scratch." \
"manual" "Keep my data   - pick a partition (dual-boot friendly)" \
"auto"   "Use whole disk - set up one disk you choose" || return 10
    PART_MODE=$REPLY
    local DISKS PARTS
    if [ "$PART_MODE" = auto ]; then
        mapfile -t DISKS < <(list_disks)
        [ "${#DISKS[@]}" -gt 0 ] || { msg "Storage" "No disks found." 8 50; return 10; }
        DISK=$(whiptail --title "Which disk to use" --cancel-button "Back" --menu \
"Pick the disk for Wheatley. Only this disk is set up;
any other disks stay exactly as they are.
(You still get a final review before anything happens.)" 16 76 6 "${DISKS[@]}" 3>&1 1>&2 2>&3) || return 10
        TARGET_DESC="$DISK  (whole disk)"
    else
        # Manual = "Keep my data": pick ONE partition. Wheatley's root, its swap
        # (a swapfile inside it) and — on BIOS — GRUB all go there. On UEFI the
        # existing EFI System Partition is found automatically (GRUB must live on
        # a FAT32 ESP, it can't go in the ext4 root). No second partition to pick.
        if whiptail --title "Edit partitions" --defaultno --yesno \
"Open cfdisk to create/resize partitions first?\n\nMost people choose No and just pick an existing partition next." 11 66; then
            mapfile -t DISKS < <(list_disks)
            local ED; ED=$(whiptail --title "Edit which disk?" --cancel-button "Back" --menu \
"Disk to open in cfdisk:" 16 74 6 "${DISKS[@]}" 3>&1 1>&2 2>&3) && { clear; cfdisk "$ED"; }
        fi
        mapfile -t PARTS < <(list_parts)
        [ "${#PARTS[@]}" -gt 0 ] || { msg "Storage" "No partitions found — create one first (cfdisk)." 9 64; return 10; }
        ROOT_PART=$(whiptail --title "Install into which partition" --cancel-button "Back" --menu \
"Pick the ONE partition to install Wheatley into.
Its root, swap and bootloader all go here.
Your other partitions and operating systems are left untouched." 18 76 8 "${PARTS[@]}" 3>&1 1>&2 2>&3) || return 10
        if whiptail --title "Format" --yesno \
"Format $ROOT_PART as ext4?\n\nYes = erase just THIS partition for a clean install (recommended).\nNo  = keep its existing files (advanced)." 12 72; then
            FORMAT_ROOT=yes; else FORMAT_ROOT=no; fi
        DISK="/dev/$(lsblk -no pkname "$ROOT_PART" | head -1)"
        if [ "$FIRMWARE" = uefi ]; then
            ESP_PART=$(find_esp "$DISK"); FORMAT_ESP=no
            if [ -z "$ESP_PART" ]; then
                msg "EFI partition needed" \
"This is a UEFI machine, so GRUB needs a small FAT32 EFI System
Partition — none was found on $DISK.

Create one (cfdisk: ~300M, type 'EFI System'), or go Back and
choose 'Use whole disk' instead." 13 72
                return 10
            fi
        fi
        TARGET_DESC="$ROOT_PART  (root + swap$([ "$FIRMWARE" = bios ] && echo ' + GRUB'); $([ "$FORMAT_ROOT" = yes ] && echo 'format' || echo 'keep'))$([ "$FIRMWARE" = uefi ] && echo "   efi: $ESP_PART (auto, kept)")"
    fi
    return 0
}
s_swap() {
    ask_input "Swap" "Swap size in GiB (0 = none — written as a swapfile on root):" "$SWAP" || return 10
    [[ "$REPLY" =~ ^[0-9]+$ ]] && SWAP=$REPLY || SWAP=0
    return 0
}

# =============================================================================
#  WIZARD DRIVER
# =============================================================================
run_wizard() {                 # returns 0 = go to summary, 10 = back to mode
    local -a steps=("$@")
    local i=0 rc
    while [ $i -lt ${#steps[@]} ]; do
        "${steps[$i]}"; rc=$?
        if [ $rc -eq 0 ]; then i=$((i+1))
        else i=$((i-1)); [ $i -lt 0 ] && return 10; fi
    done
    return 0
}

summary() {                    # returns 0 = proceed, 1 = go back
    whiptail --title "Review your choices" --yesno \
"Storage:   $TARGET_DESC
Firmware:  $FIRMWARE
Swap:      ${SWAP} GiB
Hostname:  $HOSTNAME
User:      $USERNAME
Init:      $INIT
Network:   $NETWORK
Profile:   $PROFILE
WM(s):     ${WMS:-(none)}
Terminal:  $([ "$TERMCOLOR" = amber ] && echo 'Amber theme' || echo 'Normal colours')

Start the install with these settings?
(Choose No to go back — nothing has changed yet.)" 21 74
}

# ----- main question loop -----------------------------------------------------
# Online-only install (the offline express clone mode was removed): always
# downloads packages, so it can fit the CachyOS kernel and your chosen options.
MODE=online
while true; do
    run_wizard s_net s_keyboard s_locale s_timezone s_hostname s_user s_pass \
               s_init s_netmgr s_profile s_termcolor s_storage s_swap \
        || { whiptail --title "$TITLE" --yesno "Quit the installer?" 8 50 && exit 0 || continue; }
    summary && break
done

# =============================================================================
#  EXECUTION
# =============================================================================
{
set -e          # this subshell aborts on any unguarded failure; run() records it
echo 0; echo "# Preparing storage"

# Free the target before touching it: the live environment may have auto-mounted
# a partition and a swap partition may be active, which makes mkfs / sgdisk fail
# with "device is busy".  Best-effort — never aborts.
settle() { partprobe "$DISK" 2>/dev/null || true; udevadm settle 2>/dev/null || true; }
free_target() {
    swapoff -a 2>/dev/null || true
    umount -R /mnt 2>/dev/null || true
    local p
    for p in $(lsblk -lnpo NAME "$DISK" 2>/dev/null | tac); do
        umount -R "$p" 2>/dev/null || true
    done
}
free_target; settle

# ----- partition / format (shared) -------------------------------------------
if [ "$PART_MODE" = auto ]; then
    run "wipe" wipefs -a "$DISK"
    run "zap"  sgdisk -Z "$DISK"
    settle
    case "$DISK" in *[0-9]) P="${DISK}p";; *) P="$DISK";; esac
    if [ "$FIRMWARE" = uefi ]; then
        run "gpt" sgdisk -n1:0:+512M -t1:ef00 -c1:ESP -n2:0:0 -t2:8300 -c2:ROOT "$DISK"
        ESP="${P}1"; ROOT="${P}2"; settle; run "mkesp" mkfs.fat -F32 "$ESP"
    else
        run "gpt-bios" sgdisk -n1:0:+1M -t1:ef02 -c1:BIOSBOOT -n2:0:0 -t2:8300 -c2:ROOT "$DISK"
        ROOT="${P}2"; settle
    fi
    run "mkroot" mkfs.ext4 -F "$ROOT"
else
    ROOT="$ROOT_PART"
    [ "$FORMAT_ROOT" = yes ] && run "mkroot" mkfs.ext4 -F "$ROOT"
    if [ "$FIRMWARE" = uefi ]; then
        ESP="$ESP_PART"
        [ "$FORMAT_ESP" = yes ] && run "mkesp" mkfs.fat -F32 "$ESP"
    fi
fi

echo 12; echo "# Mounting"
run "mount" mount "$ROOT" /mnt
if [ "$FIRMWARE" = uefi ]; then mkdir -p /mnt/boot/efi; run "mountesp" mount "$ESP" /mnt/boot/efi; fi
if [ "$SWAP" -gt 0 ]; then
    run "swapfile" fallocate -l "${SWAP}G" /mnt/swapfile; chmod 600 /mnt/swapfile
    run "mkswap" mkswap /mnt/swapfile; run "swapon" swapon /mnt/swapfile
fi

# terminal colour choice (shared by both modes): amber theme vs normal colours
if [ "$TERMCOLOR" = neutral ]; then
    TERMCOLOR_CMD='ln -sf /usr/share/wheatley/term-neutral.sh /etc/wheatley/termcolor.sh'
else
    TERMCOLOR_CMD='rm -f /etc/wheatley/termcolor.sh'
fi

    # ===================== CUSTOM ONLINE: basestrap + configure =============
    echo 15; echo "# Refreshing signing keys (first run can take a moment)"
    # basestrap verifies package signatures against the host keyring; make sure
    # it's initialised + populated, or downloads fail with "unknown trust".
    pacman-key --init >>"$LOG" 2>&1 || true
    pacman-key --populate artix cachyos >>"$LOG" 2>&1 || true

    echo 18; echo "# Installing base system (this takes a while)"
    BASE="base base-devel $INIT_BASE \
          linux-cachyos linux-cachyos-headers linux-firmware \
          grub efibootmgr os-prober \
          artix-keyring artix-mirrorlist cachyos-keyring cachyos-mirrorlist \
          sudo nano vim git wget"
    NET="$NET_PKGS openresolv"
    # Retry once: a single flaky mirror during DB sync / download is the most
    # common cause of a failed online install, and a retry usually clears it.
    log "basestrap"
    if ! basestrap -C "$PACCONF" /mnt $BASE $NET >>"$LOG" 2>&1; then
        log "basestrap failed — retrying once"
        if ! basestrap -C "$PACCONF" /mnt $BASE $NET >>"$LOG" 2>&1; then
            printf '%s: %s\n' "basestrap" "basestrap -C $PACCONF /mnt $BASE $NET" >"$FAILMARK"
            exit 1
        fi
    fi

    echo 55; echo "# Generating fstab"
    run "fstab" sh -c "fstabgen -U /mnt >> /mnt/etc/fstab"
    [ "$SWAP" -gt 0 ] && echo "/swapfile none swap defaults 0 0" >> /mnt/etc/fstab
    install -Dm644 "$PACCONF" /mnt/etc/pacman.conf
    if [ -d /usr/share/wheatley/repo ]; then
        mkdir -p /mnt/usr/share/wheatley; cp -a /usr/share/wheatley/repo /mnt/usr/share/wheatley/
    fi

    echo 60; echo "# Configuring system"
    DESKTOP_PKGS=""
    if [ "$PROFILE" = desktop ]; then
        DESKTOP_PKGS="xorg-server xorg-xinit xorg-xrandr xorg-xsetroot \
            $GREETD_SVC greetd greetd-tuigreet \
            pipewire wireplumber pipewire-pulse pipewire-alsa pipewire-jack \
            st-wheatley rofi dmenu fastfetch \
            firefox noto-fonts noto-fonts-emoji \
            mpv zathura zathura-pdf-mupdf feh \
            dunst pavucontrol $NET_APPLET \
            lf scrot xclip \
            ttf-dejavu ttf-jetbrains-mono \
            wheatley-branding"
        for wm in $WMS; do DESKTOP_PKGS="$DESKTOP_PKGS $wm"; done
    fi

    case "$INIT" in
        openrc) ENABLE_DEF='enable(){ rc-update add "$1" default >/dev/null 2>&1 || true; }' ;;
        runit)  ENABLE_DEF='enable(){ mkdir -p /etc/runit/runsvdir/default; ln -sf /etc/runit/sv/"$1" /etc/runit/runsvdir/default/"$1" 2>/dev/null || true; }' ;;
        *)      ENABLE_DEF='enable(){ mkdir -p /etc/dinit.d/boot.d; ln -sf "../$1" /etc/dinit.d/boot.d/"$1" 2>/dev/null || true; }' ;;
    esac

    cat >/mnt/root/wheatley-chroot.sh <<CHROOT
#!/bin/bash
set -e
ln -sf /usr/share/zoneinfo/$TZ /etc/localtime; hwclock --systohc || true
sed -i 's/^#\\($LOCALE\\)/\\1/' /etc/locale.gen; locale-gen
echo "LANG=$LOCALE" > /etc/locale.conf
echo "KEYMAP=$KEYMAP" > /etc/vconsole.conf
echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS
echo "root:$ROOTPW" | chpasswd
useradd -m -G wheel,audio,video,input,storage -s /bin/bash "$USERNAME"
echo "$USERNAME:$USERPW" | chpasswd
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers
mkinitcpio -P
if [ "$FIRMWARE" = uefi ]; then
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Wheatley
else
    grub-install --target=i386-pc "$DISK"
fi
sed -i 's/^GRUB_DISTRIBUTOR=.*/GRUB_DISTRIBUTOR="Wheatley Linux"/' /etc/default/grub
if grep -q '^GRUB_DISABLE_OS_PROBER' /etc/default/grub; then
    sed -i 's/^GRUB_DISABLE_OS_PROBER=.*/GRUB_DISABLE_OS_PROBER=false/' /etc/default/grub
else echo 'GRUB_DISABLE_OS_PROBER=false' >> /etc/default/grub; fi
# Quiet boot: stop kernel/udev log lines printing onto the greeter's VT (which
# is what makes tuigreet's input jump back and overwrite itself).
if grep -q '^GRUB_CMDLINE_LINUX_DEFAULT=' /etc/default/grub; then
    sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 rd.udev.log_level=3"/' /etc/default/grub
else
    echo 'GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 rd.udev.log_level=3"' >> /etc/default/grub
fi
mkdir -p /etc/sysctl.d
printf 'kernel.printk = 3 3 3 3\n' > /etc/sysctl.d/20-wheatley-quiet.conf
grub-mkconfig -o /boot/grub/grub.cfg
# stop ModemManager spamming the console / greeter (D-Bus-activated by NM)
for f in /usr/share/dbus-1/system-services/org.freedesktop.ModemManager1.service \
         /usr/lib/systemd/system/ModemManager.service; do
    [ -e "\$f" ] && mv -f "\$f" "\$f.wheatley-disabled" 2>/dev/null || true
done
$ENABLE_DEF
enable dbus; enable elogind; enable seatd; enable $NET_SERVICE
if [ "$PROFILE" = desktop ]; then
    enable greetd
    # Run the greeter on a DEDICATED VT (tty7), away from the kernel console and
    # boot messages (which live on tty1) and from the login gettys (tty1-6).
    # This is what makes tuigreet's input stay put instead of being overwritten.
    mkdir -p /etc/greetd
    cat > /etc/greetd/config.toml <<GREETD
[terminal]
vt = 7

[default_session]
command = "tuigreet --remember --remember-session --time --sessions /usr/share/xsessions --theme 'border=yellow;text=white;prompt=yellow;time=yellow;action=yellow;button=yellow;container=black;input=white'"
user = "greeter"
GREETD
    mkdir -p /etc/wheatley
    $TERMCOLOR_CMD
    printf '%s\\n' '# Wheatley: terminal text colour (neutral override, if chosen)' >> /etc/bash.bashrc
    printf '%s\\n' 'case \$- in *i*) [ -r /etc/wheatley/termcolor.sh ] && . /etc/wheatley/termcolor.sh;; esac' >> /etc/bash.bashrc
    printf '%s\\n' '# Wheatley: fastfetch splash on interactive shells' >> /etc/bash.bashrc
    printf '%s\\n' 'case \$- in *i*) command -v fastfetch >/dev/null 2>&1 && fastfetch --config /etc/wheatley/fastfetch.jsonc 2>/dev/null;; esac' >> /etc/bash.bashrc
fi
CHROOT
    chmod +x /mnt/root/wheatley-chroot.sh
    if [ -n "$DESKTOP_PKGS" ]; then
        echo 68; echo "# Installing desktop, WM(s), greeter, audio"
        run "desktop-pkgs" basestrap -C "$PACCONF" /mnt $DESKTOP_PKGS
    fi
    echo 85; echo "# Finalizing inside chroot"
    run "chroot" artix-chroot /mnt /root/wheatley-chroot.sh
    rm -f /mnt/root/wheatley-chroot.sh

echo 96; echo "# Unmounting"
[ "$SWAP" -gt 0 ] && swapoff /mnt/swapfile 2>/dev/null || true
run "umount" umount -R /mnt
echo 100; echo "# Done"
: >"$OKMARK"
} | whiptail --title "Installing Wheatley Linux" --gauge "Starting..." 8 70 0 || true

# If the execution subshell exited early, the OK marker is missing — show a real
# error dialog instead of falsely reporting success.
if [ ! -f "$OKMARK" ]; then
    if [ -f "$FAILMARK" ]; then die "step failed: $(cat "$FAILMARK")"
    else die "the install stopped before finishing (see $LOG)"; fi
fi

# ----- finished ---------------------------------------------------------------
if whiptail --title "Complete" --yesno \
"Wheatley Linux is installed.

Reboot now? (Remove the install media first.)" 12 60; then
    reboot
fi
