# Maintainer: Wheatley Linux
pkgname=apeturewm
pkgver=r1
pkgrel=2
pkgdesc="Small fast tiling window manager for X11 (Wheatley themed)"
arch=('x86_64')
url="https://github.com/Vifuddyxg/apeturewm"
license=('custom')
depends=('libx11' 'libxinerama' 'libxrandr' 'libxcomposite' 'libxrender'
         'xorg-xinit' 'dbus')
optdepends=('rofi: application launcher' 'st-wheatley: terminal'
            'pipewire: audio' 'wireplumber: audio session manager'
            'pipewire-pulse: PulseAudio-compatible audio')
makedepends=('git')
source=("git+https://github.com/Vifuddyxg/apeturewm.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
    cd "$srcdir/$pkgname"
    make
}

package() {
    cd "$srcdir/$pkgname"
    # install to /usr (not /usr/local) for a packaged system
    make PREFIX=/usr DESTDIR="$pkgdir" install
    # point the xsession entry at the packaged paths
    install -d "$pkgdir/usr/share/xsessions"
    sed -e 's|/usr/local/bin|/usr/bin|g' apeturewm.desktop \
        > "$pkgdir/usr/share/xsessions/apeturewm.desktop"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"

    # Ship a session wrapper that WORKS under a TUI greeter (greetd+tuigreet,
    # which doesn't start X) and brings up audio. Overrides whatever the upstream
    # checkout installed so the ISO is correct without needing a git push.
    install -Dm755 /dev/stdin "$pkgdir/usr/bin/apeturewm-session" <<'SESSION'
#!/bin/sh
# apeturewm-session — login session wrapper for greeters / display managers.
# Starts X if launched from a TUI greeter (greetd/tuigreet) with no display,
# then audio (pipewire) + session bus, then the WM.
if [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ] && [ -z "${APETUREWM_XSTARTED:-}" ]; then
    APETUREWM_XSTARTED=1; export APETUREWM_XSTARTED
    exec startx "$0" -- "vt${XDG_VTNR:-1}"
fi
export XDG_CURRENT_DESKTOP=apeturewm
export XDG_SESSION_DESKTOP=apeturewm
export XDG_SESSION_TYPE=x11
export XCURSOR_THEME=Adwaita
export XCURSOR_SIZE=24
exec dbus-run-session sh -lc '
  command -v pipewire       >/dev/null 2>&1 && pipewire &
  command -v wireplumber    >/dev/null 2>&1 && wireplumber &
  command -v pipewire-pulse >/dev/null 2>&1 && pipewire-pulse &
  exec apeturewm
'
SESSION
}
