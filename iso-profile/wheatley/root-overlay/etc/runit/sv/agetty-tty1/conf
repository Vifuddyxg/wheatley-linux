if [ -x /sbin/agetty -o -x /bin/agetty ]; then
	# util-linux specific settings
	if [ "${tty}" = "tty1" ]; then
		# Wheatley live: log the 'wheatley' user in automatically on tty1 (no
		# username/password prompt). The login shell sources
		# /etc/profile.d/wheatley-live.sh, which launches the installer.
		GETTY_ARGS="--noclear --autologin wheatley"
	fi
fi

BAUD_RATE=38400
TERM_NAME=linux
